{
  "name": "shoot-creater",
  "private": true,
  "scripts": {
    "lint": "biome lint .",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -F @shoot-creater/core typecheck && pnpm -F mobile typecheck",
    "test": "pnpm -F @shoot-creater/core test && pnpm -F mobile test",
    "test:swift": "cd apps/mobile/targets/watch && swiftc -parse-as-library Tests/SessionStateTests.swift -o /tmp/session-state-test && /tmp/session-state-test",
    "precommit": "pnpm check && pnpm typecheck && pnpm test && pnpm test:swift"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  }
}
