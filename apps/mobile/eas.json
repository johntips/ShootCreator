{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "e2e": {
      "ios": {
        "simulator": true,
        "buildConfiguration": "Release"
      },
      "env": {
        "E2E": "true"
      }
    },
    "production": {
      "autoIncrement": true
    }
  }
}
