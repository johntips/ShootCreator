{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "ios": {
        "image": "latest"
      },
      "node": "20.19.5"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_ENV": "qa"
      }
    },
    "qa": {
      "extends": "base",
      "distribution": "internal",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "APP_ENV": "qa"
      },
      "channel": "qa"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      },
      "env": {
        "APP_ENV": "production"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759998749",
        "ascApiKeyId": "323MBP9DHL",
        "ascApiKeyIssuerId": "69a6de89-b99e-47e3-e053-5b8c7c11a4d1",
        "ascApiKeyPath": "../../keys/AuthKey.p8"
      }
    }
  }
}
